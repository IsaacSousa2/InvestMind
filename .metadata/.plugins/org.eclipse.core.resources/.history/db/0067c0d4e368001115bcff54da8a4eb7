package br.claude;

public class Acao {

	private String setor;
	private double dividendoAnual;
	
	private double rentabilidadeMensal;
	
	public Acao() {
		
	}
	public Acao(String setor, double dividendoAnual) {
		
		this.setor = setor;
		this.dividendoAnual = dividendoAnual;
		
	}
	
	//Getters
	public String getSetor() {
		return this.setor;
	}
	public double getDividendoAnual() {
		return this.dividendoAnual;
	}
	
	//Setters
	public void setSetor(String setor) {
		this.setor = setor;
	}
	public void setDividendoAnual(double dividendoAnual) {
		this.dividendoAnual = dividendoAnual;
	}
	
	public void calcularRentabilidadeMensal() {
		this.setRentabilidadeMensal(dividendoAnual / 12);
	}
	public double getRentabilidadeMensal() {
		return rentabilidadeMensal;
	}
	public void setRentabilidadeMensal(double rentabilidadeMensal) {
		this.rentabilidadeMensal = rentabilidadeMensal;
	}
	
}
